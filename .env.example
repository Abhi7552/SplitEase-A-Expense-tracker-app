# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/splitease?retryWrites=true&w=majority

# JWT secret — minimum 32 random characters
JWT_SECRET=replace_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=production

# Your deployed frontend URL (used for CORS)
# Same domain if frontend+backend on same host (e.g. Render)
CLIENT_URL=https://your-app.onrender.com

# ── Twilio WhatsApp (optional) ────────────────────────────
# Get free sandbox at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WA_FROM=whatsapp:+14155238886

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx  # 16-character app password (spaces included)